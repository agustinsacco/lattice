{
  "name": "sandbox-agent",
  "projectType": "application",
  "sourceRoot": "sandbox/agent/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["docker build -t lattice-agent:latest ."],
        "cwd": "sandbox/agent"
      }
    },
    "push": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["docker build -t saccodigital/lattice-agent:$GITHUB_SHA --push ."],
        "cwd": "sandbox/agent"
      }
    }
  }
}
