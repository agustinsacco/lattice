{
  "name": "lattice",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run services:start && nodemon --watch 'apps/web/src' --watch 'apps/web/server.ts' --ext 'ts,json' --exec 'tsx --tsconfig tsconfig.json --env-file apps/web/.env.local apps/web/server.ts'",
    "build": "nx run web:build",
    "start": "NODE_ENV=production tsx apps/web/server.ts",
    "stop": "npm run services:stop",
    "services:start": "npx supabase start && npm run storage:init",
    "services:stop": "npx supabase stop && kubectl delete pods --all -n lattice-sandboxes",
    "storage:init": "tsx scripts/init-storage.ts",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@ai-sdk/google": "^2.0.23",
    "@google/generative-ai": "^0.24.1",
    "@kubernetes/client-node": "^1.4.0",
    "@next/env": "^16.0.1",
