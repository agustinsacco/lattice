{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/client/*": [
        "./src/client/*"
      ],
      "@/server/*": [
        "./src/server/*"
      ],
      "@/common/*": [
        "./src/common/*"
      ],
      "@/components/*": [
        "./src/client/components/*"
      ],
      "@lattice/shared": [
        "../../libs/shared/src/index.ts"
      ],
      "@lattice/shared/*": [
        "../../libs/shared/src/*"
      ],
      "@lattice/ui": [
        "../../libs/ui/src/index.ts"
      ],
      "@lattice/ui/*": [
        "../../libs/ui/src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "scratch"
  ]
}
